<Window x:Class="WpfCoordinates.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Преобразование координат" Height="520" Width="700"
        Background="#F0F4F8">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Преобразование систем координат"
                   FontSize="18" FontWeight="Bold" Foreground="#1E3A5F"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1" BorderBrush="#B0C4DE" BorderThickness="2"
                CornerRadius="6" Background="White">
            <Canvas x:Name="MainCanvas" ClipToBounds="True">


                <Button x:Name="MyButton"
                        Canvas.Left="60" Canvas.Top="60"
                        Width="120" Height="40"
                        Content="Нажми меня"
                        Background="#4A90D9" Foreground="White"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="Element_Click"/>

                <TextBox x:Name="MyTextBox"
                         Canvas.Left="250" Canvas.Top="80"
                         Width="160" Height="34"
                         Text="Введите текст"
                         FontSize="13"
                         VerticalContentAlignment="Center"
                         Padding="6,0"/>

                <Ellipse x:Name="MyEllipse"
                         Canvas.Left="120" Canvas.Top="180"
                         Width="100" Height="70"
                         Fill="#E8F4FD" Stroke="#4A90D9" StrokeThickness="2.5"/>

                <TextBlock Canvas.Left="138" Canvas.Top="225"
                           Text="Ellipse" FontSize="11" Foreground="#4A90D9"/>

            </Canvas>
        </Border>

        <Button Grid.Row="2" Content="Показать координаты Ellipse"
                Margin="0,12,0,0" Height="40"
                Background="#1E3A5F" Foreground="White"
                FontSize="14" FontWeight="SemiBold"
                Cursor="Hand"
                Click="ShowCoordinates_Click"/>

        <Border Grid.Row="3" Background="#EAF2FB" CornerRadius="6"
                BorderBrush="#B0C4DE" BorderThickness="1"
                Margin="0,10,0,0" Padding="12,8">
            <StackPanel>
                <TextBlock x:Name="LocalCoordsText"
                           Text="Локальные координаты (центр Ellipse): —"
                           FontSize="13" Foreground="#1E3A5F"/>
                <TextBlock x:Name="GlobalCoordsText"
                           Text="Глобальные координаты (в окне):         —"
                           FontSize="13" Foreground="#1E3A5F" Margin="0,4,0,0"/>
                <TextBlock x:Name="BackCoordsText"
                           Text="Обратное преобразование (глобал → локал): —"
                           FontSize="13" Foreground="#555" Margin="0,4,0,0"/>
                <TextBlock x:Name="ClickedElementText"
                           Text="Последний клик: —"
                           FontSize="13" Foreground="#888" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>